# ─────────────────────────────────────────────────────────────────────────────
# CallLive AI CRM — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_SECRET=your-super-secret-key-here

# ── URLs ─────────────────────────────────────────────────────────────────────
SERVER_URL=http://localhost:3000
FRONT_BASE_URL=http://localhost:3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/default
PG_DATABASE_HOST=localhost
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_STORAGE_TYPE=redis
MESSAGE_QUEUE_TYPE=bull-mq

# ── Auth Tokens (generate with: openssl rand -hex 32) ────────────────────────
ACCESS_TOKEN_SECRET=your-access-token-secret
REFRESH_TOKEN_SECRET=your-refresh-token-secret
LOGIN_TOKEN_SECRET=your-login-token-secret
FILE_TOKEN_SECRET=your-file-token-secret

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_TYPE=local
# For S3 (production):
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=ap-south-1
# STORAGE_S3_NAME=calllive-crm-storage
# STORAGE_S3_ENDPOINT=

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_FROM_ADDRESS=noreply@calllive.ai
EMAIL_FROM_NAME=CallLive AI CRM
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your@email.com
# EMAIL_SMTP_PASSWORD=your-smtp-password

# ── CallLive AI — Telephony ───────────────────────────────────────────────────
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Exotel (Indian market)
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=

# ── CallLive AI — WhatsApp ────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Sign-up ───────────────────────────────────────────────────────────────────
IS_SIGN_UP_DISABLED=false
SIGN_IN_PREFILLED=true
DEFAULT_SUBDOMAIN=calllive-ai
